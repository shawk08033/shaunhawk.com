---
import { getCollection } from "astro:content";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Card from "@/components/Card.astro";
import FeaturedPost from "@/components/FeaturedPost.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Hero from "@/components/Hero.astro";
import Hr from "@/components/Hr.astro";
import LinkButton from "@/components/LinkButton.astro";
import StructuredData from "@/components/StructuredData.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";
import getSortedPosts from "@/utils/getSortedPosts";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts).filter(({ data }) => !data.draft);
const featuredPost = sortedPosts[0];
const recentPosts = sortedPosts.slice(1, SITE.postPerIndex);
---

<Layout
  title={`${SITE.title} — Blog, Projects & Resume`}
  description="Shaun Hawk: Senior Manager, Data Management & Technology at FSM Controls. Leading the rollout, modernization, and go-to-market for Huckleberry Services."
>
  <StructuredData type="WebSite" data={{}} />
  <StructuredData type="Person" data={{}} />
  <Header />
  <main id="main-content" data-layout="index">
    <Hero />

    <Hr />

    {
      featuredPost ? (
        <section id="featured-post" class="pt-8 pb-4" aria-labelledby="featured-post-heading">
          <h2 id="featured-post-heading" class="sr-only">Featured post</h2>
          <FeaturedPost post={featuredPost} />
        </section>
      ) : null
    }

    {
      recentPosts.length > 0 ? (
        <>
          <section id="recent-posts" class="pt-10 pb-6" aria-labelledby="recent-posts-heading">
            <h2 id="recent-posts-heading" class="text-2xl font-semibold tracking-wide">More Posts</h2>
            <ul class="mt-4">
              {recentPosts.map((entry) => (
                <Card variant="h3" {...entry} />
              ))}
            </ul>
          </section>
          <div class="my-8 text-center">
            <LinkButton href="/posts/">
              All Posts
              <IconArrowRight class="inline-block" />
            </LinkButton>
          </div>
        </>
      ) : !featuredPost ? (
        <p class="mt-8 text-center text-lg text-gray-500 dark:text-gray-400">Posts Coming Soon!</p>
      ) : null
    }
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
