---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Tag from "@/components/Tag.astro";
import { SITE } from "@/config";
import { PROJECTS } from "@/data/projects";
import Layout from "@/layouts/Layout.astro";
import Main from "@/layouts/Main.astro";
---

<Layout
  title={`Projects | ${SITE.title}`}
  description="Work and side projects by Shaun Hawk — Huckleberry Services, community sites, and AI tooling."
>
  <Header />
  <Main
    pageTitle="Projects"
    pageDesc="What I'm building at work and on the side."
  >
    <ul class="space-y-6 not-prose">
      {
        PROJECTS.map((project) => (
          <li class="rounded-xl border border-border p-5 transition-shadow hover:shadow-sm">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <h2 class="text-lg font-semibold">
                <a
                  href={project.href}
                  class="text-accent decoration-dashed underline-offset-4 hover:underline"
                  {...(project.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                >
                  {project.title}
                  {project.external && <span class="sr-only"> (opens in new tab)</span>}
                </a>
              </h2>
              <span class="rounded-full border border-border bg-muted/40 px-2.5 py-0.5 text-xs font-medium">
                {project.status}
              </span>
            </div>
            <p class="mt-2 opacity-80">{project.description}</p>
            {
              project.highlights && project.highlights.length > 0 && (
                <ul class="mt-3 list-disc space-y-1 pl-5 text-sm opacity-80">
                  {project.highlights.map((highlight) => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              )
            }
            <ul class="mt-3 flex flex-wrap gap-x-2 gap-y-1" aria-label="Project tags">
              {project.tags.map((tagName) => (
                <Tag {tagName} size="sm" />
              ))}
            </ul>
          </li>
        ))
      }
    </ul>
  </Main>
  <Footer />
</Layout>
