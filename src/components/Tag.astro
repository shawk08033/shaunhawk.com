---
import IconHash from "@/assets/icons/IconHash.svg";

export interface Props {
  tagName: string;
  size?: "sm" | "lg";
}

const { tagName, size = "sm" } = Astro.props;
---

<li
  class:list={[
    "inline-block",
    size === "sm" ? "my-1" : "mx-1 my-3",
  ]}
>
  <span
    class:list={[
      "inline-flex items-center gap-1 rounded-md border border-border bg-muted/40 px-2 py-0.5 text-foreground",
      { "text-sm": size === "sm" },
      { "text-lg px-3 py-1": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[
        "inline-block opacity-80",
        { "size-3.5": size === "sm" },
        { "size-5": size === "lg" },
      ]}
    />
    <span>{tagName}</span>
  </span>
</li>
