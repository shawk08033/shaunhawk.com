---
import type { CollectionEntry } from "astro:content";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Datetime from "@/components/Datetime.astro";
import Tag from "@/components/Tag.astro";
import { SITE } from "@/config";
import { getPath } from "@/utils/getPath";
import { calculateReadingTime } from "@/utils/readingTime";
import { slugifyStr } from "@/utils/slugify";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, pubDatetime, modDatetime, timezone, tags, heroImage } = post.data;
const postPath = getPath(post.id, post.filePath);
const readingTime = calculateReadingTime(post.body ?? "");
const ogImageUrl = SITE.dynamicOgImage
  ? new URL(`${postPath}/index.png`, Astro.site ?? Astro.url).href
  : heroImage
    ? typeof heroImage === "string"
      ? heroImage
      : heroImage.src
    : new URL(`/${SITE.ogImage}`, Astro.site ?? Astro.url).href;
---

<article class="featured-post group overflow-hidden rounded-xl border border-border transition-shadow duration-300 hover:shadow-md">
  <a href={postPath} class="block no-underline">
    <div class="grid gap-0 sm:grid-cols-[minmax(0,1.1fr)_minmax(0,1.4fr)]">
      <div class="relative aspect-[16/9] overflow-hidden bg-muted/30 sm:aspect-auto sm:min-h-[220px]">
        <img
          src={ogImageUrl}
          alt=""
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
          loading="eager"
        />
        <span class="absolute top-3 left-3 rounded-md bg-accent px-2.5 py-1 text-xs font-semibold text-white">
          Latest
        </span>
      </div>

      <div class="flex flex-col justify-center p-5 sm:p-6">
        <p class="mb-2 text-xs font-semibold tracking-widest text-accent uppercase">Featured Post</p>
        <h2
          transition:name={slugifyStr(title)}
          class="text-xl font-bold text-accent decoration-dashed underline-offset-4 group-hover:underline sm:text-2xl"
        >
          {title}
        </h2>
        <div class="mt-2 flex flex-wrap items-center gap-3 text-sm opacity-80">
          <Datetime {pubDatetime} {modDatetime} {timezone} />
          <span class="italic">• {readingTime}</span>
        </div>
        <p class="mt-3 line-clamp-3 opacity-80">{description}</p>
        {
          tags.length > 0 && (
            <ul class="mt-4 flex flex-wrap gap-x-2 gap-y-1" aria-label="Tags">
              {tags.map((tagName) => (
                <Tag {tagName} size="sm" />
              ))}
            </ul>
          )
        }
        <span class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-accent">
          Read post
          <IconArrowRight class="inline-block transition-transform group-hover:translate-x-0.5" />
        </span>
      </div>
    </div>
  </a>
</article>

<style>
  .featured-post a:hover h2 {
    text-decoration: underline;
    text-decoration-style: dashed;
  }
</style>
