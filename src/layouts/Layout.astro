---
import { ClientRouter } from "astro:transitions";
import { SITE } from "@/config";
import "@/styles/global.css";
import Analytics from "@/components/Analytics.astro";

const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;

export interface Props {
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string | URL;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
  ogType?: "website" | "article";
  noIndex?: boolean;
  articleTags?: string[];
}

const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  description = SITE.desc,
  ogImage = SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  canonicalURL = new URL(Astro.url.pathname, Astro.site ?? SITE.website),
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
  ogType = pubDatetime ? "article" : "website",
  noIndex = false,
  articleTags = [],
} = Astro.props;

const canonicalHref = canonicalURL.toString();
const socialImageURL = new URL(ogImage, Astro.site ?? SITE.website).href;
const siteOrigin = (Astro.site ?? SITE.website).toString().replace(/\/$/, "");

const meLinks = [
  "https://github.com/shawk08033",
  "https://x.com/ShaunHawkCode",
  "https://bsky.app/profile/shaunhawk.com",
  "https://www.linkedin.com/in/shaun-r-hawk-3b2ab174",
];
---

<!doctype html>
<html lang={SITE.lang ?? "en"} class:list={[scrollSmooth && "scroll-smooth"]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="view-transition" content="same-origin" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#fdfdfd" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#212737" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalHref} />
    <meta name="generator" content={Astro.generator} />

    {noIndex && <meta name="robots" content="noindex, follow" />}

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    {meLinks.map((href) => <link rel="me" href={href} />)}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:alt" content={`${title} — ${SITE.title}`} />

    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }
    {
      articleTags.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))
    }

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SITE.twitterHandle} />
    <meta name="twitter:creator" content={SITE.twitterHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />
    <meta name="twitter:image:alt" content={`${title} — ${SITE.title}`} />

    <!-- Enable RSS feed auto-discovery  -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.title} RSS Feed`}
      href={`${siteOrigin}/rss.xml`}
    />

    {
      googleSiteVerification && (
        <meta
          name="google-site-verification"
          content={googleSiteVerification}
        />
      )
    }

    <ClientRouter />

    <script is:inline src="/toggle-theme.js"></script>

    <!-- Domain-based markdown redirect -->
    <script is:inline>
      const hostname = window.location.hostname;
      if ((hostname === "shaunhawk.md" || hostname === "www.shaunhawk.md") && !window.location.pathname.endsWith(".md")) {
        const mdPath = window.location.pathname === "/" ? "/index.md" : window.location.pathname + ".md";
        window.location.replace(mdPath + window.location.search + window.location.hash);
      }
    </script>
  </head>
  <body>
    <slot />
    <Analytics />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }
</style>
